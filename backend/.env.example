# Copy this file to .env and fill in your values
# Generate JWT_SECRET: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/ososdiscos?retryWrites=true&w=majority
JWT_SECRET=replace-with-64-char-random-hex-string
ALLOWED_ORIGINS=https://ososdiscos.com,https://www.ososdiscos.com
PORT=5000
NODE_ENV=production
